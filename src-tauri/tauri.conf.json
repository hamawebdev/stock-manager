{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stock Manager",
  "version": "0.1.0",
  "identifier": "com.hamawebdev.stockmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stock Manager",
        "width": 1000,
        "height": 700,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPCONFIG/product-images/**",
          "$APPDATA/product-images/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://example.com/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzOTZEQzYyRkQxRDRFRTUKUldUbFRoMzlZdHlXSTBuZCtMbTFJOFIzU2pkUEJvR3FmUjM2TDdnZFdaNWRSM1dkOHdEek1YMEEK"
    }
  }
}
